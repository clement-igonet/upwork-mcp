# Copy this file to Freelance/.env (parent directory) and fill in your values.
# The docker-compose.yml reads ../.env automatically.

MCP_TRANSPORT=sse
MCP_PORT=8080

# Primary authentication — your Upwork account credentials.
# A session is cached in ~/.upwork-mcp-session.json and reused until expiry.
UPWORK_LOGIN=you@example.com
UPWORK_PASSWD=your_upwork_password

# Optional: full browser Cookie header for broader API scopes
# (job search/details require scopes not granted by programmatic login).
# Export from Chrome DevTools → Network → any upwork.com request → Cookie header.
# UPWORK_COOKIES=cookie1=val1; cookie2=val2; ...
